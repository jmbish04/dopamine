---
import { ViewTransitions } from "astro:transitions";
import "@frontend/styles/globals.css";
import { GlobalSpotifyPlayer } from "../components/spotify/GlobalSpotifyPlayer";
import { GlobalToaster } from "../components/GlobalToaster";

type CurrentPage =
  | "dashboard"
  | "focus"
  | "planning"
  | "kanban"
  | "rewards"
  | "reflection"
  | "spotify"
  | "docs"
  | "health";

const {
  title = "Dopamine",
  current = "dashboard",
  fullWidth = false,
} = Astro.props as {
  title?: string;
  current?: CurrentPage;
  fullWidth?: boolean;
};

const nav = [
  { key: "dashboard", label: "Dashboard", href: "/" },
  { key: "focus", label: "Focus Mode", href: "/focus" },
  { key: "planning", label: "Deep Planning", href: "/planning" },
  { key: "kanban", label: "Kanban", href: "/kanban" },
  { key: "kanban-beta", label: "Kanban Beta", href: "/kanban-beta" },
  { key: "rewards", label: "Rewards Store", href: "/rewards" },
  { key: "reflection", label: "Reflection", href: "/reflection" },
  { key: "spotify", label: "Lofi Beats", href: "/spotify" },
  { key: "health", label: "System Health", href: "/health" },
  { key: "docs", label: "Documentation", href: "/docs/python-ai" },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
  </head>
  <body class="min-h-screen">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div
        class="absolute inset-x-0 top-0 h-[420px] bg-gradient-to-b from-onion-blue/12 to-transparent"
      >
      </div>
      <div
        class="absolute left-[-10%] top-16 h-96 w-96 rounded-full bg-onion-cyan/10 blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-16 right-[-8%] h-[28rem] w-[28rem] rounded-full bg-onion-orange/10 blur-3xl"
      >
      </div>
    </div>

    <header
      class="sticky top-0 z-50 border-b border-white/10 bg-background/85 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex h-16 max-w-[1440px] items-center justify-between px-4 sm:px-6"
      >
        <div class="flex items-center gap-3">
          <div
            class="flex size-10 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-onion-cyan shadow-cyan"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-6 text-onion-cyan"
              ><path
                d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"
              ></path><path
                d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"
              ></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"
              ></path><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path><path
                d="M6.002 5.125A3 3 0 0 0 6.401 6.5"></path><path
                d="M3.477 10.896a4 4 0 0 1 .585-.396"></path><path
                d="M19.938 10.5a4 4 0 0 1 .585.396"></path><path
                d="M6 18a4 4 0 0 1-1.967-.516"></path><path
                d="M19.967 17.484A4 4 0 0 1 18 18"></path></svg
            >
          </div>
          <div>
            <p class="text-lg font-semibold">Dopamine</p>
            <p class="text-xs text-muted-foreground">
              ADHD-aware momentum cockpit
            </p>
          </div>
        </div>

        <div class="hidden items-center gap-3 md:flex">
          <span class="onion-kicker">Receipt printing online</span>
          <span class="onion-kicker">Scanner wedge ready</span>
          <a
            class="rounded-full border border-white/10 px-3 py-1.5 text-sm text-muted-foreground hover:border-onion-blue/30 hover:text-foreground"
            href="/scalar">Scalar Docs</a
          >
        </div>
      </div>
    </header>

    <div
      class:list={[
        "mx-auto grid gap-6 px-4 py-6 md:grid-cols-[260px_minmax(0,1fr)] md:px-6",
        fullWidth ? "w-full" : "max-w-[1440px]",
      ]}
    >
      <aside
        class="onion-panel sticky top-24 hidden h-[calc(100vh-7rem)] flex-col overflow-hidden md:flex"
      >
        <div class="border-b border-white/10 p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-muted-foreground">
            Command Center
          </p>
          <h1 class="mt-2 text-2xl font-semibold">Stay inside the onion</h1>
          <p class="mt-2 text-sm text-muted-foreground">
            One Worker, one queue of reality, and one printed receipt per next
            action.
          </p>
        </div>

        <nav class="flex flex-1 flex-col gap-2 p-4">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "rounded-2xl px-4 py-3 text-sm font-medium transition",
                  current === item.key
                    ? "bg-white text-black shadow-glow"
                    : "text-muted-foreground hover:bg-white/5 hover:text-foreground",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="border-t border-white/10 p-4">
          <div
            class="rounded-2xl border border-onion-blue/20 bg-onion-blue/10 p-4"
          >
            <p class="text-xs uppercase tracking-[0.24em] text-onion-cyan">
              Research cue
            </p>
            <p class="mt-2 text-sm text-white">
              Show the next smallest visible action, not the whole mountain.
            </p>
          </div>
        </div>
      </aside>

      <main class="min-w-0 pb-32">
        <slot />
      </main>
    </div>

    <div transition:persist="spotify-player">
      <GlobalSpotifyPlayer client:only="react" />
    </div>
    <div transition:persist="toaster">
      <GlobalToaster client:only="react" />
    </div>
  </body>
</html>
