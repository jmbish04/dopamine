{
  "name": "dopamine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "browser": {
    "ai": false
  },
  "description": "Dopamine unified Cloudflare Worker",
  "main": "src/backend/index.ts",
  "scripts": {
    "build": "npm run build:frontend && npm run build:worker",
    "build:frontend": "astro build",
    "build:worker": "wrangler deploy --dry-run --outdir dist/worker",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "npm run db:generate && y | wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "npm run db:generate && y | wrangler d1 migrations apply DB --remote",
    "deploy": "npm run build:frontend && npm run db:migrate:remote && wrangler deploy",
    "deploy:tail": "rm -f wrangler.log && pnpm run deploy && wrangler tail --format pretty | tee wrangler.log",
    "tail": "rm -f wrangler.log && wrangler tail --format pretty | tee wrangler.log",
    "dev:frontend": "astro dev",
    "types": "WRANGLER_LOG_PATH=/tmp/wrangler-types.log wrangler types worker-configuration.d.ts --include-runtime false"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@cloudflare/sandbox": "^0.7.12",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@scalar/hono-api-reference": "^0.9.48",
    "@tailwindcss/vite": "^4.2.1",
    "agents": "^0.7.5",
    "astro": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "cloudflare": "^5.2.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "honidev": "^0.5.5",
    "hono": "^4.12.5",
    "luxon": "^3.7.2",
    "openai": "^6.27.0",
    "postal-mime": "^2.7.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "2.15.4",
    "refractor": "^5.0.0",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tunnel-rat": "^0.1.2",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260305.1",
    "@google/genai": "^1.44.0",
    "@openai/agents": "^0.5.4",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@shikijs/transformers": "^4.0.1",
    "@types/luxon": "^3.7.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "lucide-react": "^0.542.0",
    "postcss": "^8.5.8",
    "react-icons": "^5.6.0",
    "shiki": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
