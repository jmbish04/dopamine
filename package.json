{
  "name": "focus-onion",
  "version": "1.0.0",
  "description": "Cloudflare Worker Project",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply focus-onion-db --remote",
    "migrate:db": "wrangler d1 migrations apply focus-onion-db --local",
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "cli": "node local_cli/index.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260304.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.68.1"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "@hono/zod-openapi": "^0.9.5",
    "@scalar/hono-api-reference": "^0.5.6",
    "zod": "^3.22.4",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "node-fetch": "^3.3.2"
  }
}
